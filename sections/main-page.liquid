<section class="section-shell page-shell">
  <div class="page-width page-shell__inner">
    <div class="page-shell__intro js-reveal" data-reveal>
      <p class="eyebrow">Wingstone</p>
      <h1 class="page-shell__title section-title">{{ page.title }}</h1>
      <p class="page-shell__lede section-subtext">Editorial brand pages, clear product stories, and no default Shopify clutter.</p>
    </div>

    <article class="page-shell__panel rte page-content js-reveal" data-reveal>
      {{ page.content }}
    </article>

    <div class="page-shell__actions">
      <a class="button" href="{{ routes.root_url }}#featured-products">Shop drops</a>
      <a class="button button--ghost" href="{{ routes.root_url }}#trust">Brand values</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main page",
  "settings": []
}
{% endschema %}
