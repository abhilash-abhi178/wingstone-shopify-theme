<section class="hero hero--tones">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="hero__pattern" aria-hidden="true"></div>
  <div class="page-width hero__inner">
    <!-- Background Brand -->
    <div class="brand-bg" aria-hidden="true">{{ section.settings.heading }}</div>

    <!-- Main Content -->
    <div class="hero-content">
      {% if section.settings.badge != blank %}
        <p class="badge">{{ section.settings.badge }}</p>
      {% endif %}

      {% if section.settings.eyebrow != blank %}
        <h1>{{ section.settings.eyebrow }}</h1>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="desc">{{ section.settings.text }}</p>
      {% endif %}

      {% if section.settings.primary_label != blank or section.settings.secondary_label != blank %}
        <div class="buttons">
          {% if section.settings.primary_label != blank %}
            <a class="button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
          {% endif %}
          {% if section.settings.secondary_label != blank %}
            <a class="button outline" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <!-- Moving Ticker -->
    {% if section.settings.announcement_text != blank %}
      <div class="ticker-wrap" aria-hidden="true">
        <div class="ticker">
          <span>{{ section.settings.announcement_text }}</span>
          <span>{{ section.settings.announcement_text }}</span>
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Wingstone hero",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Premium essentials, trusted by style-first shoppers"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Hero heading",
      "default": "Elevate every fit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Backdrop text",
      "default": "Wingstone"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Refined pieces with sharp silhouettes, premium finishes, and offers that make confident shopping effortless.</p>"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Moving announcement text",
      "default": "Discount codes / Offers / Announcements / New drops / Limited pieces"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop collection"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "View lookbook"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },

    {
      "type": "text",
      "id": "stat_two_number",
      "label": "Stat two number",
      "default": "10%"
    },
    {
      "type": "text",
      "id": "stat_two_label",
      "label": "Stat two label",
      "default": "Active offer"
    },
    {
      "type": "text",
      "id": "stat_three_number",
      "label": "Stat three number",
      "default": "24/7"
    },
    {
      "type": "text",
      "id": "stat_three_label",
      "label": "Stat three label",
      "default": "Order support"
    }
  ],
  "presets": [
    {
      "name": "Wingstone hero"
    }
  ]
}
{% endschema %}
