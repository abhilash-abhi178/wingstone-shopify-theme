<!-- ========================= -->
<!-- WINGSTONE PREMIUM PRODUCT SECTION -->
<!-- Replace product-variant-picker.liquid -->
<!-- ========================= -->

<div class="wingstone-product-options">

  <!-- COLOR VARIANTS -->
  <div class="wingstone-option-group">

    <div class="wingstone-option-title">
      COLOR:
      <span id="selectedColor">
        {{ product.selected_or_first_available_variant.option1 }}
      </span>
    </div>

    <div class="wingstone-color-grid">

      {% for value in product.options_with_values[0].values %}

        {% assign variant = product.variants | where: 'option1', value | first %}

        <label class="wingstone-color-card {% if forloop.first %}active{% endif %}">

          <input
            type="radio"
            name="Color"
            value="{{ value }}"
            data-variant-id="{{ variant.id }}"
            hidden
            {% if forloop.first %}checked{% endif %}
          >

          {% if variant.featured_image %}
            <img
              src="{{ variant.featured_image | image_url: width: 200 }}"
              alt="{{ value }}"
              loading="lazy"
            >
          {% endif %}

          <div class="wingstone-color-info">
            <span class="wingstone-color-name">
              {{ value }}
            </span>

            <span class="wingstone-color-price">
              {{ variant.price | money }}
            </span>
          </div>

        </label>

      {% endfor %}

    </div>

  </div>


  <!-- SIZE VARIANTS -->
  <div class="wingstone-option-group">

    <div class="wingstone-option-title">
      SIZE:
      <span id="selectedSize">
        {{ product.selected_or_first_available_variant.option2 }}
      </span>

      <a href="#" class="wingstone-size-chart">
        Size Chart
      </a>
    </div>

    <div class="wingstone-size-grid">

      {% for value in product.options_with_values[1].values %}

        {% assign size_variant = product.variants | where: 'option2', value | first %}

        <button
          type="button"
          class="wingstone-size-btn {% if size_variant.available == false %}disabled{% endif %}"
          data-size="{{ value }}"
        >
          {{ value }}
        </button>

      {% endfor %}

    </div>

  </div>


  <!-- QUANTITY -->
  <div class="wingstone-option-group">

    <div class="wingstone-option-title">
      QUANTITY
    </div>

    <div class="wingstone-quantity-box">

      <button type="button" class="qty-minus">
        −
      </button>

      <input
        type="number"
        id="quantity"
        value="1"
        min="1"
      >

      <button type="button" class="qty-plus">
        +
      </button>

    </div>

  </div>


  <!-- TRUST FEATURES -->
  <div class="wingstone-trust-grid">

    <div class="trust-item">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
      Secure Checkout
    </div>

    <div class="trust-item">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h13v13H3z"/><path d="M16 8h4l1 2v6h-5z"/></svg>
      Fast Shipping
    </div>

    <div class="trust-item">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>
      Easy Returns
    </div>

    <div class="trust-item">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8a6 6 0 0 0-12 0v4H4v8h16v-8h-2z"/></svg>
      Premium Support
    </div>

  </div>


  <!-- BUTTONS -->
  <div class="wingstone-buttons">

    <button
      type="button"
      class="wingstone-cart-btn"
      id="wingstoneAddToCart"
    >
      Add to Cart
    </button>

    <button
      type="button"
      class="wingstone-buy-btn"
    >
      Buy It Now
    </button>

  </div>

</div>



<style>

.wingstone-product-options{
  width:100%;
  max-width:550px;
  margin-top:20px;
}

.wingstone-option-group{
  margin-bottom:32px;
}

.wingstone-option-title{
  font-size:13px;
  font-weight:700;
  letter-spacing:2px;
  color:#1e293b;
  margin-bottom:16px;
}

.wingstone-option-title span{
  margin-left:5px;
  font-weight:600;
}

.wingstone-color-grid{
  display:flex;
  gap:14px;
  overflow-x:auto;
  padding-bottom:5px;
}

.wingstone-color-card{
  min-width:125px;
  border:1px solid #dbe2ea;
  border-radius:16px;
  padding:10px;
  background:#fff;
  cursor:pointer;
  transition:.3s ease;
}

.wingstone-color-card:hover{
  transform:translateY(-3px);
  box-shadow:0 10px 25px rgba(0,0,0,.08);
}

.wingstone-color-card.active{
  border:2px solid #2563eb;
  box-shadow:0 0 0 4px rgba(37,99,235,.12);
}

.wingstone-color-card img{
  width:100%;
  border-radius:12px;
}

.wingstone-color-info{
  margin-top:10px;
}

.wingstone-color-name{
  display:block;
  font-size:14px;
  font-weight:600;
}

.wingstone-color-price{
  color:#64748b;
  font-size:13px;
}

.wingstone-size-grid{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
}

.wingstone-size-btn{
  min-width:60px;
  height:48px;
  border:1px solid #cbd5e1;
  border-radius:12px;
  background:#fff;
  font-weight:700;
  cursor:pointer;
  transition:.25s ease;
}

.wingstone-size-btn:hover{
  border-color:#1e293b;
}

.wingstone-size-btn.active{
  background:#1e3a8a;
  color:#fff;
  border-color:#1e3a8a;
}

.wingstone-size-btn.disabled{
  opacity:.35;
  cursor:not-allowed;
  text-decoration:line-through;
}

.wingstone-size-chart{
  margin-left:10px;
  color:#2563eb;
  text-decoration:none;
  font-size:13px;
}

.wingstone-quantity-box{
  display:flex;
  align-items:center;
  width:180px;
  border:1px solid #dbe2ea;
  border-radius:16px;
  overflow:hidden;
}

.wingstone-quantity-box input{
  width:80px;
  height:52px;
  border:none;
  text-align:center;
  font-size:18px;
}

.wingstone-quantity-box input:focus{
  outline:none;
}

.qty-minus,
.qty-plus{
  width:50px;
  height:52px;
  border:none;
  background:#f8fafc;
  font-size:24px;
  cursor:pointer;
}

.wingstone-trust-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:12px;
  margin-bottom:28px;
}

.trust-item{
  display:flex;
  align-items:center;
  gap:8px;
  background:#f8fafc;
  padding:14px;
  border-radius:14px;
  font-size:14px;
  color:#334155;
}

.wingstone-buttons{
  display:flex;
  flex-direction:column;
  gap:14px;
}

.wingstone-cart-btn{
  width:100%;
  height:58px;
  border:none;
  border-radius:16px;
  background:linear-gradient(135deg,#0f172a,#1e3a8a);
  color:#fff;
  font-size:16px;
  font-weight:700;
  cursor:pointer;
  transition:.3s ease;
  box-shadow:0 10px 25px rgba(30,58,138,.18);
}

.wingstone-buy-btn{
  width:100%;
  height:58px;
  border:none;
  border-radius:16px;
  background:#111827;
  color:#fff;
  font-size:16px;
  font-weight:700;
  cursor:pointer;
  transition:.3s ease;
}

.wingstone-cart-btn:hover,
.wingstone-buy-btn:hover{
  transform:translateY(-2px);
}

@media(max-width:768px){

  .wingstone-buttons{
    position:sticky;
    bottom:0;
    background:#fff;
    padding-top:12px;
    z-index:50;
  }

}

</style>



<script>

let selectedVariantId =
document.querySelector('[data-variant-id]').dataset.variantId;


/* COLOR SELECTION */

document.querySelectorAll('.wingstone-color-card')
.forEach(card=>{

  card.addEventListener('click',()=>{

    document.querySelectorAll('.wingstone-color-card')
    .forEach(c=>c.classList.remove('active'));

    card.classList.add('active');

    selectedVariantId =
    card.querySelector('input').dataset.variantId;

    document.getElementById('selectedColor')
    .innerText =
    card.querySelector('.wingstone-color-name').innerText;

  });

});


/* SIZE SELECTION */

document.querySelectorAll('.wingstone-size-btn')
.forEach(btn=>{

  btn.addEventListener('click',()=>{

    if(btn.classList.contains('disabled')) return;

    document.querySelectorAll('.wingstone-size-btn')
    .forEach(b=>b.classList.remove('active'));

    btn.classList.add('active');

    document.getElementById('selectedSize')
    .innerText =
    btn.dataset.size;

  });

});


/* QUANTITY */

const qtyInput =
document.getElementById('quantity');

document.querySelector('.qty-plus')
.onclick = ()=>{

  qtyInput.value =
  parseInt(qtyInput.value)+1;

};

document.querySelector('.qty-minus')
.onclick = ()=>{

  if(parseInt(qtyInput.value)>1){

    qtyInput.value =
    parseInt(qtyInput.value)-1;

  }

};


/* AJAX ADD TO CART */

document.getElementById('wingstoneAddToCart')
.addEventListener('click', async ()=>{

  const quantity =
  parseInt(qtyInput.value);

  await fetch('/cart/add.js',{

    method:'POST',

    headers:{
      'Content-Type':'application/json'
    },

    body:JSON.stringify({
      id:selectedVariantId,
      quantity:quantity
    })

  });

  const cart =
  await fetch('/cart.js')
  .then(r=>r.json());

  const bubble =
  document.querySelector('.cart-count-bubble');

  if(bubble){

    bubble.textContent =
    cart.item_count;

  }

});


</script>