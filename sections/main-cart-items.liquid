<section class="section-shell cart-page">
  <div class="page-width cart-page__grid">
    <div class="cart-page__top js-reveal" data-reveal>
      <p class="eyebrow">Cart</p>
      <h1 class="cart-page__title section-title">Your selection</h1>
      <p class="section-subtext">A sharper cart that keeps quantity, subtotal, and checkout cues close together.</p>
    </div>

    <div class="cart-page__panel js-reveal" data-reveal>
      {% if cart.item_count > 0 %}
        <form action="{{ routes.cart_url }}" method="post" class="cart-page__form">
          <div class="cart-page__items">
            {% for item in cart.items %}
              {% render 'cart-item', item: item %}
            {% endfor %}
          </div>
          <div class="cart-drawer__summary">
            <span>Subtotal</span>
            <strong class="cart-drawer__subtotal">{{ cart.total_price | money }}</strong>
          </div>
          <div class="cart-drawer__actions">
            <button class="button button--secondary" type="submit" name="update">Update cart</button>
            <button class="button" type="submit" name="checkout">Checkout</button>
          </div>
        </form>
      {% else %}
        <p class="cart-drawer__empty">Your cart is empty.</p>
        <a class="button" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cart items",
  "settings": []
}
{% endschema %}
