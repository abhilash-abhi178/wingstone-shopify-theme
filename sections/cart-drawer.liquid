<div class="cart-drawer__backdrop" data-cart-drawer-backdrop hidden></div>
<aside class="cart-drawer" data-cart-drawer data-free-shipping-threshold="{{ section.settings.free_shipping_threshold | times: 100 }}" hidden aria-hidden="true" aria-label="Shopping cart" role="dialog" aria-modal="true">
  <div class="cart-drawer__panel">
    <div class="cart-drawer__top">
      <div>
        <p class="eyebrow">Cart</p>
        <h2 class="section-title">Your selection</h2>
      </div>
      <button class="cart-drawer__close" type="button" aria-label="Close cart" data-close-cart>
        {% render 'icon', name: 'close' %}
      </button>
    </div>
    <div class="cart-drawer__body" data-cart-drawer-content>
      <p class="cart-drawer__loading">Loading cart...</p>
    </div>
    <div class="cart-drawer__footer">
      <div class="cart-drawer__summary">
        <span>Subtotal</span>
        <strong class="cart-drawer__subtotal">{{ cart.total_price | money }}</strong>
      </div>
      <div class="cart-drawer__actions">
        <a class="button button--secondary" href="{{ routes.cart_url }}">View cart</a>
        <a class="cart-drawer__checkout" href="{{ routes.checkout_url }}">Checkout</a>
      </div>
    </div>
  </div>
</aside>

<div class="toast" role="status" aria-live="polite" hidden data-toast>
  <span data-toast-text></span>
</div>

{% schema %}
{
  "name": "Cart drawer",
  "settings": [
    { "type": "range", "id": "free_shipping_threshold", "label": "Free shipping threshold", "min": 25, "max": 500, "step": 5, "default": 70 }
  ]
}
{% endschema %}
