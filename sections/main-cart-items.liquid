<section class="section">
  <div class="page-width">
    <h1 class="section-title">Cart</h1>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post">
        <table class="cart-table">
          <thead>
            <tr>
              <th>Item</th>
              <th>Quantity</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            {% for item in cart.items %}
              <tr>
                <td>
                  <strong>{{ item.product.title }}</strong><br>
                  <small>{{ item.variant.title }}</small>
                </td>
                <td>
                  <input class="field" type="number" name="updates[]" value="{{ item.quantity }}" min="0">
                </td>
                <td>{{ item.final_line_price | money }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>

        <div class="cart-total">
          <strong>{{ cart.total_price | money }}</strong>
          <button class="button button--secondary" type="submit">Update</button>
          <button class="button" name="checkout" type="submit">Checkout</button>
        </div>
      </form>
    {% else %}
      <p>Your cart is empty.</p>
      <a class="button" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Cart items",
  "settings": []
}
{% endschema %}
