<aside class="mobile-menu-drawer" data-mobile-menu-drawer hidden aria-hidden="true" aria-label="Mobile menu" role="dialog" aria-modal="true">
  <div class="mobile-menu-drawer__backdrop" data-mobile-menu-backdrop></div>
  <div class="mobile-menu-drawer__panel">
    <div class="mobile-menu-drawer__top">
      <div>
        <p class="mobile-menu-drawer__eyebrow">Wingstone</p>
        <h2 class="mobile-menu-drawer__title">Menu</h2>
      </div>
      <button class="mobile-drawer__close" type="button" aria-label="Close menu" data-close-mobile-menu>
        {% render 'icon', name: 'close' %}
      </button>
    </div>

    <nav class="mobile-menu-drawer__nav" aria-label="Mobile navigation">
      {% assign menu_handle = section.settings.menu %}
      {% assign mobile_menu = linklists[menu_handle] %}
      {% if mobile_menu.links.size > 0 %}
        {% for link in mobile_menu.links %}
          <a class="mobile-menu-drawer__link" href="{{ link.url }}">{{ link.title }} {% render 'icon', name: 'arrow-right' %}</a>
        {% endfor %}
      {% else %}
        <a class="mobile-menu-drawer__link" href="{{ routes.root_url }}">Home {% render 'icon', name: 'arrow-right' %}</a>
        <a class="mobile-menu-drawer__link" href="{{ routes.all_products_collection_url }}">Shop {% render 'icon', name: 'arrow-right' %}</a>
        <a class="mobile-menu-drawer__link" href="{{ pages.about.url | default: routes.root_url }}">About us {% render 'icon', name: 'arrow-right' %}</a>
      {% endif %}
    </nav>

    <div class="mobile-menu-drawer__meta">
      <a class="mobile-drawer__login" href="{{ routes.account_login_url }}">Login</a>
      <div class="social-list">
        <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram">{% render 'icon', name: 'instagram' %}</a>
        <a href="https://facebook.com" target="_blank" rel="noopener" aria-label="Facebook">{% render 'icon', name: 'facebook' %}</a>
      </div>
    </div>
  </div>
</aside>

{% schema %}
{
  "name": "Mobile menu drawer",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ]
}
{% endschema %}
