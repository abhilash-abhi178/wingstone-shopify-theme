<section class="section page-shell">
  <div class="page-width page-shell__inner">
    <div class="page-shell__intro">
      <p class="eyebrow">Wingstone</p>
      <h1 class="section-title">Your Wishlist</h1>
      <p class="page-shell__lede" id="wishlistCountLede">Keep track of your favorite collectible pieces.</p>
    </div>

    <div id="wishlistEmpty" class="page-shell__card rte page-content" style="display: none; text-align: center; padding: 4rem 1rem;">
      <p style="margin-bottom: 2rem;">Your wishlist is currently empty.</p>
      <a class="button" href="{{ routes.all_products_collection_url }}">Explore Collection</a>
    </div>

    <div id="wishlistGrid" class="product-grid" style="display: none; margin-top: 2rem;">
      <!-- Wishlisted products will be inserted here dynamically -->
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const grid = document.getElementById('wishlistGrid');
  const empty = document.getElementById('wishlistEmpty');
  const lede = document.getElementById('wishlistCountLede');

  const loadWishlist = () => {
    const items = [];
    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i);
      if (key.startsWith('wl_')) {
        try {
          const val = localStorage.getItem(key);
          const data = JSON.parse(val);
          if (data && data.id) {
            items.push(data);
          }
        } catch (e) {
          // If it was stored as '1' or invalid JSON, ignore
        }
      }
    }

    if (items.length === 0) {
      empty.style.display = 'block';
      grid.style.display = 'none';
      lede.textContent = 'Keep track of your favorite collectible pieces.';
    } else {
      empty.style.display = 'none';
      grid.style.display = 'grid';
      lede.textContent = `You have ${items.length} item${items.length === 1 ? '' : 's'} saved in your wishlist.`;

      grid.innerHTML = items.map(item => `
        <div class="product-card" data-product-id="${item.id}">
          <div class="product-card__image-wrapper">
            <a href="${item.url || '#'}" class="product-card__link">
              <img src="${item.img || ''}" alt="${item.title || ''}" loading="lazy" class="main-image">
            </a>
            <button
              type="button"
              class="product-card__wishlist-btn active"
              aria-label="Remove ${item.title || ''} from wishlist"
              aria-pressed="true"
              data-wishlist-toggle
              data-product-id="${item.id}"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </button>
          </div>
          <div class="product-card__info" style="padding-top: 1rem;">
            <h3 class="product-card__title" style="margin-bottom: 0.5rem; font-size: 14px;">
              <a href="${item.url || '#'}" style="text-decoration: none; color: inherit;">${item.title || ''}</a>
            </h3>
            <div class="product-card__price-row">
              ${item.comparePrice ? `<s class="product-card__price-compare" style="opacity: 0.5; margin-right: 8px;">${item.comparePrice}</s>` : ''}
              <span class="product-card__price" style="font-weight: 700;">${item.price || ''}</span>
            </div>
          </div>
        </div>
      `).join('');
    }
  };

  loadWishlist();

  // Handle removals directly on the wishlist page
  document.body.addEventListener('click', (e) => {
    const btn = e.target.closest('#wishlistGrid [data-wishlist-toggle]');
    if (!btn) return;
    
    const id = btn.dataset.productId;
    if (id) {
      localStorage.removeItem('wl_' + id);
      loadWishlist();
      
      // Update header count if available
      if (window.updateWishlistCount) {
        window.updateWishlistCount();
      }
    }
  });
});
</script>

{% schema %}
{
  "name": "Wishlist page",
  "settings": []
}
{% endschema %}
