<footer class="site-footer">
  <div class="page-width site-footer__grid">
    <div class="site-footer__panel js-reveal" data-reveal>
      <p class="eyebrow">Wingstone</p>
      <p class="site-footer__brand">{{ shop.name | default: 'Wingstone' }}</p>
      <p class="site-footer__copy">Cinematic streetwear storefronts, sharper product storytelling, and premium mobile conversion flows built for limited drops.</p>
      <div class="social-list">
        <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram">{% render 'icon', name: 'instagram' %}</a>
        <a href="https://facebook.com" target="_blank" rel="noopener" aria-label="Facebook">{% render 'icon', name: 'facebook' %}</a>
      </div>
    </div>

    <div class="site-footer__menus">
      <details open>
        <summary>Shop</summary>
        <div class="site-footer__links">
          <a href="{{ routes.all_products_collection_url }}">All products</a>
          <a href="{{ routes.collections_url }}">Collections</a>
          <a href="{{ routes.root_url }}#featured-products">Featured drop</a>
        </div>
      </details>

      <details>
        <summary>Support</summary>
        <div class="site-footer__links">
          <a href="{{ routes.root_url }}#trust">Shipping and delivery</a>
          <a href="{{ pages.contact.url | default: routes.root_url }}">Contact us</a>
          <a href="{{ routes.root_url }}">Returns</a>
        </div>
      </details>

      <details>
        <summary>Brand</summary>
        <div class="site-footer__links">
          <a href="{{ pages.about.url | default: routes.root_url }}">About Wingstone</a>
          <a href="{{ routes.root_url }}#newsletter">Join the list</a>
          <a href="{{ routes.root_url }}">Instagram</a>
        </div>
      </details>
    </div>

    <div class="footer-newsletter__panel js-reveal" data-reveal>
      <p class="eyebrow">Newsletter</p>
      <h2 class="section-title" style="font-size: clamp(1.8rem, 5vw, 3rem);">Private access to drops</h2>
      <p class="site-footer__copy">A sharper, quieter list for restocks, lookbooks, and early access.</p>
      {% form 'customer', class: 'footer-newsletter__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input class="footer-newsletter__input" type="email" name="contact[email]" placeholder="Email address" required>
        <button class="button" type="submit">Join now</button>
      {% endform %}
      <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name | default: 'Wingstone' }}. All rights reserved.</small>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "footer"
    }
  ]
}
{% endschema %}
