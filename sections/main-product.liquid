<section class="section">
  <div class="page-width product">
    <div class="product__media">
      {% assign product_images = product.images %}

      {% if product_images.size > 1 %}
        <div class="product-gallery" data-product-gallery>
          <div class="product-gallery__thumbs" aria-label="Product image thumbnails">
            {% for image in product_images %}
              <button
                class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
                type="button"
                data-product-gallery-thumb
                data-full="{{ image | image_url: width: 1400 }}"
                data-alt="{{ image.alt | default: product.title | escape }}"
                aria-label="View image {{ forloop.index }} of {{ product_images.size }}"
                {% if forloop.first %}aria-current="true"{% endif %}
              >
                <img src="{{ image | image_url: width: 180 }}" alt="{{ image.alt | default: product.title | escape }}" loading="lazy">
              </button>
            {% endfor %}
          </div>

          <div class="product-gallery__main">
            <img
              src="{{ product.featured_image | image_url: width: 1400 }}"
              alt="{{ product.title | escape }}"
              loading="eager"
              data-product-gallery-main-image
            >
          </div>
        </div>
      {% else %}
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" loading="eager">
        {% else %}
          {{ 'product-1' | placeholder_svg_tag }}
        {% endif %}
      {% endif %}
    </div>

    <div class="product__info">
      <p class="eyebrow">{{ product.vendor | default: shop.name }}</p>
      <h1 class="product__title">{{ product.title }}</h1>
      <div class="purchase-price">
        <span class="purchase-price__current" data-current-price>{{ product.selected_or_first_available_variant.price | money }}</span>
        {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
          <span class="purchase-price__compare" data-compare-price>{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
        {% endif %}
      </div>

      {% if product.description != blank %}
        {% capture cleaned_description %}
          {% assign description_blocks = product.description | split: '</p>' %}
          {% for block in description_blocks %}
            {% assign block_text = block | strip_html | strip | downcase %}
            {% unless block_text contains 'product weight' or block_text contains 'ship weight' or block_text contains 'length (cm)' or block_text contains 'breadth (cm)' or block_text contains 'height (cm)' %}
              {{ block }}{% if block != blank %}</p>{% endif %}
            {% endunless %}
          {% endfor %}
        {% endcapture %}

        {% assign cleaned_description_text = cleaned_description | strip_html | strip %}
        {% if cleaned_description_text != blank %}
          <div class="product__description">{{ cleaned_description }}</div>
        {% endif %}
      {% endif %}

      {% form 'product', product, class: 'product-form' %}
        {% assign selected_variant = product.selected_or_first_available_variant %}

        {% unless product.has_only_default_variant %}
          <div class="amazon-product-options">
            {% assign color_option = nil %}
            {% assign size_option = nil %}
            {% for option in product.options_with_values %}
              {% assign option_name_downcase = option.name | downcase %}
              {% if option_name_downcase contains 'color' or option_name_downcase contains 'colour' %}
                {% assign color_option = option %}
              {% elsif option_name_downcase contains 'size' %}
                {% assign size_option = option %}
              {% endif %}
            {% endfor %}

            {% if color_option %}
              <div class="variant-group">
                <div class="variant-title">COLOR: <span id="selectedColor">{{ color_option.selected_value }}</span></div>
                <div class="color-variants" data-option-group data-option-index="1">
                  {% assign option_index = color_option.position0 %}
                  {% for value in color_option.values %}
                    {% assign matching_variant = nil %}
                    {% for variant in product.variants %}
                      {% if variant.options[option_index] == value %}
                        {% assign matching_variant = variant %}
                        {% break %}
                      {% endif %}
                    {% endfor %}
                    <label class="color-card{% if color_option.selected_value == value %} is-active{% endif %}" data-option-value="{{ value | escape }}" data-option-index="1">
                      <img src="{% if matching_variant and matching_variant.image %}{{ matching_variant.image | image_url: width: 240, height: 240, crop: 'center' }}{% else %}{{ 'product-1' | placeholder_svg_tag }}{% endif %}" alt="{{ value | escape }}">
                      <div class="variant-info">
                        <span class="variant-name">{{ value }}</span>
                        <span class="variant-price">{{ matching_variant.price | default: selected_variant.price | money }}</span>
                      </div>
                    </label>
                  {% endfor %}
                </div>
              </div>
            {% endif %}

            {% if size_option %}
              <div class="variant-group">
                <div class="variant-title">SIZE: <span id="selectedSize">{{ size_option.selected_value }}</span>
                  <a href="#" class="size-chart" data-size-chart-trigger>Size Chart</a>
                </div>
                <div class="size-variants" data-option-group data-option-index="2">
                  {% assign option_index = size_option.position0 %}
                  {% for value in size_option.values %}
                    {% assign available = false %}
                    {% for variant in product.variants %}
                      {% if variant.options[option_index] == value and variant.available %}
                        {% assign available = true %}
                        {% break %}
                      {% endif %}
                    {% endfor %}
                    <button type="button" class="size-btn{% unless available %} disabled{% endunless %}{% if size_option.selected_value == value %} is-active{% endif %}" data-option-value="{{ value | escape }}" data-option-index="2">{{ value }}</button>
                  {% endfor %}
                </div>
              </div>
            {% endif %}

            <div class="variant-group">
              <div class="variant-title">QUANTITY</div>
              <div class="quantity-box">
                <button type="button" class="qty-btn minus" aria-label="Decrease">−</button>
                <input type="number" value="1" min="1" class="qty-input" data-quantity-input>
                <button type="button" class="qty-btn plus" aria-label="Increase">+</button>
              </div>
            </div>

            <div class="trust-badges">
              <div>🚚 Free Shipping</div>
              <div>💵 Cash on Delivery</div>
              <div>🔒 Secure Checkout</div>
              <div>↩ Easy Returns</div>
            </div>

            <div class="product-buttons">
              <button type="submit" class="cart-btn purchase-actions__add">Add to cart</button>
              <div class="purchase-actions__buy-now">{{ form | payment_button }}</div>
            </div>
          </div>
        {% endunless %}

        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <div class="purchase-quantity" aria-label="Quantity selector">
          <span class="purchase-quantity__label">Quantity</span>
          <div class="purchase-quantity__control">
            <button type="button" class="purchase-quantity__button" data-quantity-change="decrease" aria-label="Decrease quantity">−</button>
            <input class="purchase-quantity__input" type="number" name="quantity" value="1" min="1" inputmode="numeric" data-quantity-input>
            <button type="button" class="purchase-quantity__button" data-quantity-change="increase" aria-label="Increase quantity">+</button>
          </div>
        </div>

        <div class="purchase-trust" aria-label="Purchase reassurance">
          <div class="purchase-trust__item">
            <span class="purchase-trust__icon" aria-hidden="true">✓</span>
            <span>Secure checkout</span>
          </div>
          <div class="purchase-trust__item">
            <span class="purchase-trust__icon" aria-hidden="true">↺</span>
            <span>Easy returns</span>
          </div>
          <div class="purchase-trust__item">
            <span class="purchase-trust__icon" aria-hidden="true">⛟</span>
            <span>Free shipping</span>
          </div>
          <div class="purchase-trust__item">
            <span class="purchase-trust__icon" aria-hidden="true">⌂</span>
            <span>COD available</span>
          </div>
        </div>

        <p class="purchase-stock" data-stock-note hidden></p>

        <div class="purchase-actions">
          <button class="button purchase-actions__add" type="submit" {% unless product.available %}disabled{% endunless %}>
            {% if product.available %}Add to cart{% else %}Sold out{% endif %}
          </button>
          {% if product.available %}
            <div class="purchase-actions__buy-now">
              {{ form | payment_button }}
            </div>
          {% endif %}
        </div>

        <div class="purchase-meta">
          <div class="purchase-meta__item">
            <strong>Delivery estimate</strong>
            <span>2-4 business days</span>
          </div>
          <div class="purchase-meta__item">
            <strong>Low stock</strong>
            <span data-low-stock-copy>Hurry, limited quantities available.</span>
          </div>
        </div>

        {% if product.available %}
          <p class="purchase-security-note">Secure checkout. 30-day easy returns.</p>
        {% endif %}
        <script type="application/json" data-product-variants>{{ product.variants | json }}</script>
      {% endform %}
    </div>
  </div>

  <div class="size-chart-modal" id="size-chart-modal" data-size-chart-modal aria-hidden="true" role="dialog" aria-labelledby="size-chart-title">
    <div class="size-chart-modal__backdrop" data-size-chart-close></div>
    <div class="size-chart-modal__card">
      <div class="size-chart-modal__header">
        <h2 id="size-chart-title" class="size-chart-modal__title">Size Chart</h2>
        <button type="button" class="size-chart-modal__close" data-size-chart-close aria-label="Close size chart">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M6 6l12 12M18 6 6 18"></path>
          </svg>
        </button>
      </div>
      <div class="size-chart-modal__body">
        <div class="size-chart-tabs" role="tablist" aria-label="Size chart units">
          <button type="button" class="size-chart-tab is-active" data-tab-target="inches" role="tab" aria-selected="true">Inches</button>
          <button type="button" class="size-chart-tab" data-tab-target="cm" role="tab" aria-selected="false">Centimeters</button>
        </div>

        <div class="size-chart-content is-active" id="size-chart-inches" role="tabpanel">
          <table class="size-chart-table">
            <thead>
              <tr>
                <th>Size</th>
                <th>Chest (in)</th>
                <th>Length (in)</th>
                <th>Sleeve (in)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><strong>XS</strong></td><td>36</td><td>26</td><td>24</td></tr>
              <tr><td><strong>S</strong></td><td>38</td><td>27</td><td>24.5</td></tr>
              <tr><td><strong>M</strong></td><td>40</td><td>28</td><td>25</td></tr>
              <tr><td><strong>L</strong></td><td>42</td><td>29</td><td>25.5</td></tr>
              <tr><td><strong>XL</strong></td><td>44</td><td>30</td><td>26</td></tr>
              <tr><td><strong>XXL</strong></td><td>46</td><td>31</td><td>26.5</td></tr>
            </tbody>
          </table>
        </div>

        <div class="size-chart-content" id="size-chart-cm" role="tabpanel">
          <table class="size-chart-table">
            <thead>
              <tr>
                <th>Size</th>
                <th>Chest (cm)</th>
                <th>Length (cm)</th>
                <th>Sleeve (cm)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><strong>XS</strong></td><td>91</td><td>66</td><td>61</td></tr>
              <tr><td><strong>S</strong></td><td>97</td><td>69</td><td>62</td></tr>
              <tr><td><strong>M</strong></td><td>102</td><td>71</td><td>64</td></tr>
              <tr><td><strong>L</strong></td><td>107</td><td>74</td><td>65</td></tr>
              <tr><td><strong>XL</strong></td><td>112</td><td>76</td><td>66</td></tr>
              <tr><td><strong>XXL</strong></td><td>117</td><td>79</td><td>67</td></tr>
            </tbody>
          </table>
        </div>

        <p class="size-chart-modal__note">* All measurements are of the actual garment. Please allow 0.5" - 1" tolerance due to manual measurement.</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
