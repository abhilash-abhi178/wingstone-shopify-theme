<footer class="site-footer">
  <div class="page-width site-footer__inner site-footer__inner--accordion" data-footer-accordions>
    <div class="site-footer__brand-block">
      <p class="site-footer__brand">{{ shop.name | default: 'Wingstone' }}</p>
      <p class="site-footer__philosophy">Future-focused streetwear with a quieter, more premium shopping experience.</p>
      <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name | default: 'Wingstone' }}. All rights reserved.</small>
    </div>
    <div class="site-footer__accordion-group">
      <details class="site-footer__accordion" data-footer-accordion>
        <summary class="site-footer__summary">Get to Know Us</summary>
        <div class="site-footer__panel">
          <a href="{{ pages.about.url | default: routes.root_url }}">About Us</a>
          <a href="{{ routes.root_url }}#contact">Contact Us</a>
          <a href="{{ routes.root_url }}">Investment Opportunity</a>
          <a href="{{ routes.root_url }}">Influencer Hiring</a>
        </div>
      </details>

      <details class="site-footer__accordion" data-footer-accordion>
        <summary class="site-footer__summary">Policies</summary>
        <div class="site-footer__panel">
          <a href="{{ routes.cart_url }}">Track Order</a>
          <a href="{{ routes.cart_url }}">Exchange/Return Request</a>
          <a href="{{ routes.root_url }}">Terms and Conditions</a>
          <a href="{{ routes.root_url }}">Privacy Policy</a>
          <a href="{{ routes.root_url }}">Return &amp; Exchange Policy</a>
          <a href="{{ routes.root_url }}">Shipping and Delivery Policy</a>
        </div>
      </details>

      <details class="site-footer__accordion" data-footer-accordion>
        <summary class="site-footer__summary">Follow Us</summary>
        <div class="site-footer__panel">
          <a href="https://instagram.com" target="_blank" rel="noopener">Instagram</a>
        </div>
      </details>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "footer"
    }
  ]
}
{% endschema %}
