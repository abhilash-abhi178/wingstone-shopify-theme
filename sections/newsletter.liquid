<section id="contact" class="section newsletter">
  <div class="page-width">
    {% if section.settings.eyebrow != blank %}
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% if section.settings.text != blank %}
      <div>{{ section.settings.text }}</div>
    {% endif %}

    <style>
      .newsletter__success {
        color: #1e8449;
        font-size: 14px;
        padding: 12px 16px;
        background: #e9f7ef;
        border-radius: 8px;
        border: 1px solid #a9dfbf;
        margin-top: 10px;
        text-align: center;
      }
      .newsletter__error {
        color: #c0392b;
        font-size: 13px;
        margin-bottom: 10px;
        text-align: center;
      }
      .newsletter__fields {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
        margin-top: 14px;
      }
      .newsletter__fields .field {
        max-width: 320px;
        flex: 1;
      }
    </style>

    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {% if form.posted_successfully? %}
        <p class="newsletter__success" role="status">
          ✓ You're on the list. Watch your inbox for early access.
        </p>
      {% else %}
        {% if form.errors %}
          <p class="newsletter__error" role="alert">
            {{ form.errors | default_errors }}
          </p>
        {% endif %}
        <div class="newsletter__fields">
          <input
            class="field"
            type="email"
            name="contact[email]"
            aria-label="Email address"
            placeholder="Email address"
            autocomplete="email"
            required
          >
          <button class="button" type="submit">
            {{ section.settings.button_label | default: 'Subscribe' }}
          </button>
        </div>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Private list"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join Wingstone"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>New drops, restocks, and early access notes.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
