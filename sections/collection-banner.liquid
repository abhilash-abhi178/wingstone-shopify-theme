{% liquid
  assign banner_image = section.settings.image
  assign banner_collection = collections[section.settings.collection]
%}

<section class="section-shell collection-banner">
  <div class="page-width collection-banner__grid">
    <div class="collection-banner__panel js-reveal" data-reveal>
      {% if banner_image != blank %}
        <div class="collection-banner__media">{{ banner_image | image_url: width: 1800 | image_tag: loading: 'lazy', alt: section.settings.heading }}</div>
      {% endif %}
      <div class="collection-banner__content">
        {% if section.settings.eyebrow != blank %}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
        <h2 class="collection-banner__title">{{ section.settings.heading }}</h2>
        {% if section.settings.copy != blank %}<p class="collection-banner__copy">{{ section.settings.copy }}</p>{% endif %}
        {% if banner_collection != blank %}
          {% render 'button', label: section.settings.button_label, href: banner_collection.url %}
        {% else %}
          {% render 'button', label: section.settings.button_label, href: section.settings.button_link %}
        {% endif %}
      </div>
    </div>

    <div class="collection-banner__panel js-reveal" data-reveal>
      <div class="newsletter__panel">
        <p class="eyebrow">{{ section.settings.side_eyebrow }}</p>
        <h3 class="section-title" style="font-size: clamp(1.8rem, 4.5vw, 3.2rem);">{{ section.settings.side_heading }}</h3>
        <p class="section-subtext">{{ section.settings.side_copy }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated chapter" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built as a cinematic collection story" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Full-bleed visuals, strong typography, and a slower editorial pace that makes each collection feel premium." },
    { "type": "image_picker", "id": "image", "label": "Banner image" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop collection" },
    { "type": "url", "id": "button_link", "label": "Button link", "default": "/collections/all" },
    { "type": "text", "id": "side_eyebrow", "label": "Side eyebrow", "default": "Why Wingstone hits different" },
    { "type": "text", "id": "side_heading", "label": "Side heading", "default": "Made for a cleaner mobile flow" },
    { "type": "textarea", "id": "side_copy", "label": "Side copy", "default": "The layout keeps product discovery, urgency, and trust cues in a tighter rhythm so the storefront feels elevated on smaller screens." }
  ],
  "presets": [{ "name": "Collection banner" }]
}
{% endschema %}
