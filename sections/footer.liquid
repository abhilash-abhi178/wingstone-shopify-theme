<footer class="site-footer">
  <div class="page-width site-footer__inner">
    <div>
      <p class="site-footer__brand">{{ shop.name | default: 'Wingstone' }}</p>
      <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name | default: 'Wingstone' }}. All rights reserved.</small>
    </div>
    <div>
      {% assign footer_menu = linklists[section.settings.menu] %}
      {% if footer_menu and footer_menu.links.size > 0 %}
        {% for link in footer_menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>{% unless forloop.last %} &nbsp;/&nbsp; {% endunless %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "footer"
    }
  ]
}
{% endschema %}
