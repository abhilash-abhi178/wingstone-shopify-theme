        {% endcapture %}
        {% assign cleaned_text = cleaned_description | strip_html | strip %}
        {% if cleaned_text != blank %}
          <div class="pdp-divider"></div>
          <div class="pdp-description">{{ cleaned_description }}</div>
        {% endif %}
      {% endif %}

