{% liquid
  assign icon_name = name | default: 'arrow-right'
%}

<svg class="icon icon--{{ icon_name }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
  {% case icon_name %}
    {% when 'menu' %}
      <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    {% when 'search' %}
      <circle cx="11" cy="11" r="6.5" fill="none" stroke="currentColor" stroke-width="1.8" />
      <path d="m16 16 4 4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    {% when 'wishlist' %}
      <path d="M12 21s-7-4.35-9.35-8.2C.8 9.05 2.2 5.5 5.75 4.7c1.88-.42 3.5.2 4.93 1.68 1.43-1.48 3.05-2.1 4.92-1.68 3.56.8 4.97 4.35 3.1 8.1C19 16.65 12 21 12 21Z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
    {% when 'cart' %}
      <path d="M4 5h2l1.5 9.2a2 2 0 0 0 2 1.7h6.6a2 2 0 0 0 2-1.5L19.5 8H7.1" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <circle cx="10" cy="19" r="1.5" fill="currentColor" />
      <circle cx="17" cy="19" r="1.5" fill="currentColor" />
    {% when 'account' %}
      <path d="M12 12.2A4.2 4.2 0 1 0 12 4a4.2 4.2 0 0 0 0 8.2ZM4 20.4c0-3.3 3.6-5.7 8-5.7s8 2.4 8 5.7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
    {% when 'close' %}
      <path d="m5 5 14 14M19 5 5 19" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    {% when 'plus' %}
      <path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    {% when 'minus' %}
      <path d="M5 12h14" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    {% when 'eye' %}
      <path d="M2.5 12s3.8-6.5 9.5-6.5 9.5 6.5 9.5 6.5-3.8 6.5-9.5 6.5S2.5 12 2.5 12Z" fill="none" stroke="currentColor" stroke-width="1.7" />
      <circle cx="12" cy="12" r="2.8" fill="none" stroke="currentColor" stroke-width="1.7" />
    {% when 'shield' %}
      <path d="M12 3.8 19 6.6v5.3c0 4.6-2.8 7.8-7 8.5-4.2-.7-7-3.9-7-8.5V6.6L12 3.8Z" fill="none" stroke="currentColor" stroke-width="1.7" />
      <path d="m9.1 12.1 1.9 1.9 3.9-4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" />
    {% when 'truck' %}
      <path d="M3 7h10v8H3zM13 10h4l2.5 2.5V15H13z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.7" />
      <circle cx="7" cy="17" r="1.5" fill="none" stroke="currentColor" stroke-width="1.7" />
      <circle cx="17" cy="17" r="1.5" fill="none" stroke="currentColor" stroke-width="1.7" />
    {% when 'return' %}
      <path d="M8 8H4v4M4.5 12a7 7 0 1 0 2.1-4.9" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" />
    {% when 'badge' %}
      <path d="M12 4.5 14.4 7l3.5.6-.8 3.4.8 3.5-3.5.6-2.4 2.5L9.6 15l-3.5-.6.8-3.5-.8-3.4 3.5-.6L12 4.5Z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
    {% when 'bag' %}
      <path d="M7 8V7a5 5 0 0 1 10 0v1M6 8h12l-1 11H7L6 8Z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
    {% when 'instagram' %}
      <rect x="4.5" y="4.5" width="15" height="15" rx="4" fill="none" stroke="currentColor" stroke-width="1.7" />
      <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.7" />
      <circle cx="17" cy="7" r="1" fill="currentColor" />
    {% when 'facebook' %}
      <path d="M14.5 8.2H16V5.5h-1.9c-2.1 0-3.4 1.4-3.4 3.6V11H9v2.8h1.7V19H14v-5.2h2l.3-2.8H14V9.3c0-.7.2-1.1.5-1.1Z" fill="currentColor" />
    {% when 'arrow-right' %}
      <path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    {% else %}
      <path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
  {% endcase %}
</svg>
