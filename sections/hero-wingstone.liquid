<section class="hero hero--tones">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="hero__pattern" aria-hidden="true"></div>
  <div class="page-width hero__inner">
    <a class="hero__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {% if settings.logo != blank %}
        {{ settings.logo | image_url: width: 380 | image_tag: class: 'hero__logo', alt: shop.name }}
      {% else %}
        <img class="hero__logo" src="{{ 'wingstone-logo.png' | asset_url }}" alt="{{ shop.name | default: 'Wingstone' }}">
      {% endif %}
    </a>
    <p class="hero__backdrop" aria-hidden="true">{{ section.settings.heading }}</p>

    <div class="hero__content">
      {% if section.settings.badge != blank %}
        <div class="hero__badge"><span aria-hidden="true">*</span>{{ section.settings.badge }}</div>
      {% endif %}
      {% if section.settings.eyebrow != blank %}
        <h1 class="hero__offer">{{ section.settings.eyebrow }}</h1>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="hero__text">{{ section.settings.text }}</div>
      {% endif %}
      {% if section.settings.primary_label != blank or section.settings.secondary_label != blank %}
        <div class="hero__buttons">
          {% if section.settings.primary_label != blank %}
            <a class="button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
          {% endif %}
          {% if section.settings.secondary_label != blank %}
            <a class="button button--secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
          {% endif %}
        </div>
      {% endif %}
      {% if section.settings.announcement_text != blank %}
        <div class="hero__ticker" aria-label="{{ section.settings.announcement_text | strip_html | escape }}">
          <div class="hero__ticker-track">
            {% for i in (1..2) %}
              <span>{{ section.settings.announcement_text }}</span>
              <span>{{ section.settings.announcement_text }}</span>
              <span>{{ section.settings.announcement_text }}</span>
            {% endfor %}
          </div>
        </div>
      {% endif %}
      <div class="hero__stats" aria-label="Store highlights">
        <div class="hero__stat">
          <strong>{{ section.settings.stat_one_number }}</strong>
          <span>{{ section.settings.stat_one_label }}</span>
        </div>
        <span class="hero__stat-divider" aria-hidden="true"></span>
        <div class="hero__stat">
          <strong>{{ section.settings.stat_two_number }}</strong>
          <span>{{ section.settings.stat_two_label }}</span>
        </div>
        <span class="hero__stat-divider" aria-hidden="true"></span>
        <div class="hero__stat">
          <strong>{{ section.settings.stat_three_number }}</strong>
          <span>{{ section.settings.stat_three_label }}</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wingstone hero",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Premium essentials, trusted by style-first shoppers"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Hero heading",
      "default": "Elevate every fit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Backdrop text",
      "default": "Wingstone"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Refined pieces with sharp silhouettes, premium finishes, and offers that make confident shopping effortless.</p>"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Moving announcement text",
      "default": "Discount codes / Offers / Announcements / New drops / Limited pieces"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop collection"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "View lookbook"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },

    {
      "type": "text",
      "id": "stat_two_number",
      "label": "Stat two number",
      "default": "10%"
    },
    {
      "type": "text",
      "id": "stat_two_label",
      "label": "Stat two label",
      "default": "Active offer"
    },
    {
      "type": "text",
      "id": "stat_three_number",
      "label": "Stat three number",
      "default": "24/7"
    },
    {
      "type": "text",
      "id": "stat_three_label",
      "label": "Stat three label",
      "default": "Order support"
    }
  ],
  "presets": [
    {
      "name": "Wingstone hero"
    }
  ]
}
{% endschema %}
