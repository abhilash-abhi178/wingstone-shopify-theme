<section class="section-shell trust-icons" id="trust">
  <div class="page-width">
    <div class="trust-icons__top js-reveal" data-reveal>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
    </div>

    <div class="trust-icons__grid">
      {% for block in section.blocks %}
        <article class="trust-icons__item js-reveal" data-reveal {{ block.shopify_attributes }}>
          <div class="trust-icons__icon">{% render 'icon', name: block.settings.icon %}</div>
          <h3 class="trust-icons__title">{{ block.settings.title }}</h3>
          <p class="trust-icons__copy">{{ block.settings.copy }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust icons",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Trust signals" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Premium flow, zero friction" }
  ],
  "blocks": [
    { "type": "item", "name": "Item", "settings": [
      { "type": "select", "id": "icon", "label": "Icon", "default": "truck", "options": [
        { "value": "truck", "label": "Free shipping" },
        { "value": "return", "label": "Returns" },
        { "value": "shield", "label": "Secure payment" },
        { "value": "badge", "label": "Quality" }
      ] },
      { "type": "text", "id": "title", "label": "Title", "default": "Free Shipping" },
      { "type": "textarea", "id": "copy", "label": "Copy", "default": "Fast dispatch cues without clutter." }
    ] }
  ],
  "presets": [{ "name": "Trust icons", "blocks": [
    { "type": "item", "settings": { "icon": "truck", "title": "Free Shipping", "copy": "Complimentary shipping on prepaid orders." } },
    { "type": "item", "settings": { "icon": "return", "title": "Easy Returns", "copy": "Simple exchanges with no awkward friction." } },
    { "type": "item", "settings": { "icon": "shield", "title": "Secure Payment", "copy": "Encrypted checkout with trusted gateways." } },
    { "type": "item", "settings": { "icon": "badge", "title": "Premium Quality", "copy": "Carefully selected materials and finish." } }
  ] }]
}
{% endschema %}
