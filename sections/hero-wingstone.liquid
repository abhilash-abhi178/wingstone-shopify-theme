<section class="hero hero--tones">
  <div class="page-width hero__inner">
    <p class="hero__backdrop" aria-hidden="true">{{ section.settings.heading }}</p>

    <div class="hero__content">
      <span class="hero__rule" aria-hidden="true"></span>
      {% if section.settings.eyebrow != blank %}
        <h1 class="hero__offer">{{ section.settings.eyebrow }}</h1>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="hero__text">{{ section.settings.text }}</div>
      {% endif %}
      {% if section.settings.primary_label != blank or section.settings.secondary_label != blank %}
        <div class="hero__buttons">
          {% if section.settings.primary_label != blank %}
            <a class="button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
          {% endif %}
          {% if section.settings.secondary_label != blank %}
            <a class="button button--secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
          {% endif %}
        </div>
      {% endif %}
      <span class="hero__rule" aria-hidden="true"></span>
      {% if section.settings.announcement_text != blank %}
        <div class="hero__ticker" aria-label="{{ section.settings.announcement_text | strip_html | escape }}">
          <div class="hero__ticker-track">
            {% for i in (1..2) %}
              <span>{{ section.settings.announcement_text }}</span>
              <span>{{ section.settings.announcement_text }}</span>
              <span>{{ section.settings.announcement_text }}</span>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wingstone hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Offer heading",
      "default": "Under 999"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Backdrop text",
      "default": "Wingstone"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Explore curated pieces<br>Extra 10% OFF &bull; Use Code: TFV10</p>"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Moving announcement text",
      "default": "Discount codes / Offers / Announcements / New drops / Limited pieces"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop collection"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "View lookbook"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    }
  ],
  "presets": [
    {
      "name": "Wingstone hero"
    }
  ]
}
{% endschema %}
