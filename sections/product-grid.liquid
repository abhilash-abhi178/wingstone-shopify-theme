{% liquid
  assign grid_collection = collections[section.settings.collection]
  if grid_collection == blank
    assign grid_collection = collection
  endif
  if grid_collection == blank
    assign grid_collection = collections.all
  endif
%}

<section class="section-shell product-grid-section" id="product-grid">
  <div class="page-width">
    <div class="product-grid__top js-reveal" data-reveal>
      {% if section.settings.eyebrow != blank %}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}<p class="section-subtext">{{ section.settings.text }}</p>{% endif %}
    </div>

    <div class="product-grid">
      {% if grid_collection != blank and grid_collection.products_count > 0 %}
        {% for product in grid_collection.products limit: section.settings.products_to_show %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        {% for i in (1..8) %}
          <article class="product-card">
            <div class="product-card__media">{{ 'product-' | append: i | placeholder_svg_tag }}</div>
            <div class="product-card__content">
              <p class="product-card__vendor">Wingstone</p>
              <h3 class="product-card__title">Premium product placeholder</h3>
              <div class="product-card__pricing">{{ 199900 | money }}</div>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>

    {% if grid_collection != blank and grid_collection.url != blank %}
      <div class="product-grid__actions">
        <a class="button button--secondary" href="{{ grid_collection.url }}">Browse more</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Featured products" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A tighter drop grid" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Mobile-first cards with cleaner spacing, clearer pricing, and quick add interactions." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 4, "max": 16, "step": 1, "default": 8 }
  ],
  "presets": [{ "name": "Product grid" }]
}
{% endschema %}
