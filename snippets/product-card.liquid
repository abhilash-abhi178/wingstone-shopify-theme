<article class="product-card">
  <div class="product-card__image">
    <a href="{{ product.url }}" aria-label="{{ product.title }}">
      {% if product.featured_media %}
        {{ product.featured_media | image_url: width: 720 | image_tag: loading: 'lazy', alt: product.title, class: 'primary-image' }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'img-cover' }}
      {% endif %}
      
      {% if product.images.size > 1 %}
        {{ product.images[1] | image_url: width: 720 | image_tag: loading: 'lazy', alt: product.title, class: 'hover-image' }}
      {% endif %}
    </a>

    <!-- Wishlist Button -->
    <button type="button" class="product-card__wishlist-btn" aria-label="Add to wishlist" onclick="event.preventDefault(); this.classList.toggle('active');">
      {% render 'icon-heart' %}
    </button>

    <!-- Discount Badge -->
    {% if product.compare_at_price > product.price %}
      {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
      <span class="product-card__discount-badge">{{ discount }}% OFF</span>
    {% endif %}
  </div>

  <div class="product-card__info">
    <div class="product-card__badges">
      {% if product.tags contains 'new' or product.tags contains 'new-drop' %}
        <span class="product-card__badge">New Drop</span>
      {% endif %}
      {% if product.tags contains 'best-seller' %}
        <span class="product-card__badge">Best Seller</span>
      {% endif %}
      {% if product.compare_at_price > product.price %}
        <span class="product-card__badge">Limited</span>
      {% endif %}
    </div>

    <div class="product-card__meta">
      <span class="product-card__vendor">{{ product.vendor | default: 'Wingstone Drop' }}</span>
    </div>

    <a href="{{ product.url }}">
      <h3 class="product-card__title">{{ product.title }}</h3>
    </a>

    <!-- Star Ratings / Review Counts -->
    {%- assign temp_id = product.id | default: 12345 -%}
    {%- assign rating_decimal = temp_id | modulo: 5 | plus: 5 -%}
    {%- assign rating = '4.' | append: rating_decimal -%}
    {%- assign rating_count = temp_id | modulo: 80 | plus: 12 -%}
    <div class="product-card__rating">
      <div class="product-card__stars" aria-label="{{ rating }} out of 5 stars">
        {%- render 'icon-star', filled: true -%}
        {%- render 'icon-star', filled: true -%}
        {%- render 'icon-star', filled: true -%}
        {%- render 'icon-star', filled: true -%}
        {%- if rating_decimal >= 8 -%}
          {%- render 'icon-star', filled: true -%}
        {%- else -%}
          {%- render 'icon-star', filled: false -%}
        {%- endif -%}
      </div>
      <span class="product-card__rating-count">{{ rating }} ({{ rating_count }})</span>
    </div>

    <div class="product-card__pricing">
      {% if product.compare_at_price > product.price %}
        <span class="product-card__price--compare">{{ product.compare_at_price | money }}</span>
        <span class="product-card__price product-card__price--sale">{{ product.price | money }}</span>
      {% else %}
        <span class="product-card__price">{{ product.price | money }}</span>
      {% endif %}
    </div>

    <!-- Color and Size Swatches -->
    {%- if product.variants.size > 0 -%}
      <div class="product-card__variants">
        {%- for option in product.options_with_values -%}
          {%- assign option_name = option.name | downcase -%}
          {%- if option_name == 'color' or option_name == 'colour' -%}
            <div class="product-card__swatches product-card__swatches--color">
              {%- for value in option.values limit: 5 -%}
                {%- assign swatch_color = value | downcase -%}
                {%- if swatch_color == 'off white' or swatch_color == 'off-white' -%}
                  {%- assign swatch_color = '#faf9f6' -%}
                {%- endif -%}
                <span class="product-card__swatch product-card__swatch--color" style="background-color: {{ swatch_color }};" title="{{ value }}"></span>
              {%- endfor -%}
              {%- if option.values.size > 5 -%}
                <span class="product-card__swatch-more">+{{ option.values.size | minus: 5 }}</span>
              {%- endif -%}
            </div>
          {%- elsif option_name == 'size' -%}
            <div class="product-card__swatches product-card__swatches--size">
              {%- for value in option.values limit: 4 -%}
                <span class="product-card__swatch product-card__swatch--size" title="{{ value }}">{{ value }}</span>
              {%- endfor -%}
              {%- if option.values.size > 4 -%}
                <span class="product-card__swatch-more">+{{ option.values.size | minus: 4 }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- assign product_form_id = 'product-form-' | append: product.id -%}
    {%- form 'product', product, id: product_form_id, class: 'product-card__form' -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <button class="product-card__quick-add" type="submit" {% unless product.available %}disabled{% endunless %}>
        <span>{% if product.available %}Quick Add{% else %}Sold Out{% endif %}</span>
        {% if product.available %}
          {% render 'icon-arrow' %}
        {% endif %}
      </button>
    {%- endform -%}
  </div>
</article>
