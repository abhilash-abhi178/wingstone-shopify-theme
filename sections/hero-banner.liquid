{% liquid
  assign media_image = section.settings.image
  assign has_video = section.settings.video != blank
%}

<section class="hero-banner" data-parallax-root data-hero-animate>
  <div class="hero-banner__media" aria-hidden="true">
    {% if has_video %}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
    {% elsif media_image != blank %}
      {{ media_image | image_url: width: 2200 | image_tag: class: 'hero-banner__image', loading: 'eager', alt: section.settings.heading }}
    {% endif %}
    <div class="hero-banner__overlay"></div>
  </div>

  <div class="page-width hero-banner__inner">
    <div class="hero-banner__content js-reveal" data-reveal>
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow" data-animate-item>{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1 class="hero-banner__title" data-animate-item>{{ section.settings.heading }}</h1>
      {% if section.settings.text != blank %}
        <div class="hero-banner__text" data-animate-item>{{ section.settings.text }}</div>
      {% endif %}
      <div class="hero-banner__actions" data-animate-item>
        {% render 'button', label: section.settings.primary_label, href: section.settings.primary_link %}
        {% render 'button', label: section.settings.secondary_label, href: section.settings.secondary_link, variant: 'secondary' %}
      </div>
      <div class="hero-banner__stats" data-animate-item>
        <div class="hero-banner__stat"><strong>{{ section.settings.stat_one_number }}</strong><span>{{ section.settings.stat_one_label }}</span></div>
        <div class="hero-banner__stat"><strong>{{ section.settings.stat_two_number }}</strong><span>{{ section.settings.stat_two_label }}</span></div>
        <div class="hero-banner__stat"><strong>{{ section.settings.stat_three_number }}</strong><span>{{ section.settings.stat_three_label }}</span></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Cinematic drop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Wingstone, designed like a frame from a campaign" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Immersive fashion commerce with editorial pacing, limited-drop urgency, and a calmer premium shopping flow.</p>" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "video", "id": "video", "label": "Hero video" },
    { "type": "text", "id": "primary_label", "label": "Primary label", "default": "Shop drop" },
    { "type": "url", "id": "primary_link", "label": "Primary link", "default": "/collections/all" },
    { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Explore story" },
    { "type": "url", "id": "secondary_link", "label": "Secondary link", "default": "/pages/about" },
    { "type": "text", "id": "stat_one_number", "label": "Stat one number", "default": "01" },
    { "type": "text", "id": "stat_one_label", "label": "Stat one label", "default": "Featured drop" },
    { "type": "text", "id": "stat_two_number", "label": "Stat two number", "default": "24/7" },
    { "type": "text", "id": "stat_two_label", "label": "Stat two label", "default": "Order support" },
    { "type": "text", "id": "stat_three_number", "label": "Stat three number", "default": "5.0" },
    { "type": "text", "id": "stat_three_label", "label": "Stat three label", "default": "Brand feel" }
  ],
  "presets": [{ "name": "Hero banner" }]
}
{% endschema %}
