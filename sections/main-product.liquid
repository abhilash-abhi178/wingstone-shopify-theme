        <script>

        let selectedVariantId = (document.querySelector('[data-variant-id]') || {}).dataset?.variantId || {{ product.selected_or_first_available_variant.id }};


        /* COLOR SELECTION */

        document.querySelectorAll('.wingstone-color-card')
        .forEach(card=>{

          card.addEventListener('click',()=>{

            document.querySelectorAll('.wingstone-color-card')
            .forEach(c=>c.classList.remove('active'));

            card.classList.add('active');

            const input = card.querySelector('input[data-variant-id]');
            if (input) selectedVariantId = input.dataset.variantId;
            const vidInput = document.getElementById('variantId');
            if (vidInput) vidInput.value = selectedVariantId;

            document.getElementById('selectedColor')
            .innerText =
            card.querySelector('.wingstone-color-name').innerText;

          });

        });


        /* SIZE SELECTION */

        document.querySelectorAll('.wingstone-size-btn')
        .forEach(btn=>{

          btn.addEventListener('click',()=>{

            if(btn.classList.contains('disabled')) return;

            document.querySelectorAll('.wingstone-size-btn')
            .forEach(b=>b.classList.remove('active'));

            btn.classList.add('active');

            document.getElementById('selectedSize')
            .innerText =
            btn.dataset.size;

          });

        });


        /* QUANTITY */

        const qtyInput =
        document.getElementById('quantity');

        document.querySelector('.qty-plus')
        .onclick = ()=>{

          qtyInput.value =
          parseInt(qtyInput.value)+1;

        };

        document.querySelector('.qty-minus')
        .onclick = ()=>{

          if(parseInt(qtyInput.value)>1){

            qtyInput.value =
            parseInt(qtyInput.value)-1;

          }
        };


        /* AJAX ADD TO CART */

        document.getElementById('wingstoneAddToCart')
        .addEventListener('click', async ()=>{

          const quantity =
          parseInt(qtyInput.value);

          await fetch('/cart/add.js',{

            method:'POST',

            headers:{
              'Content-Type':'application/json'
            },

            body:JSON.stringify({
              id:selectedVariantId,
              quantity:quantity
            })

          });

          const cart =
          await fetch('/cart.js')
          .then(r=>r.json());

          const bubble =
          document.querySelector('.site-header__badge');

          if(bubble){

            bubble.textContent =
            cart.item_count;

          }

        });


        </script>

      {% endform %}

      <!-- Description -->
