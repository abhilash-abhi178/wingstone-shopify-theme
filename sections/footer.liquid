<footer class="site-footer">
  <div class="page-width site-footer__inner">
    <div>
      <p class="site-footer__brand">{{ shop.name | default: 'Wingstone' }}</p>
      <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name | default: 'Wingstone' }}. All rights reserved.</small>
    </div>
    <div>
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>{% unless forloop.last %} &nbsp;/&nbsp; {% endunless %}
      {% endfor %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "footer"
    }
  ]
}
{% endschema %}
